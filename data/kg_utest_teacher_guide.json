{
  "meta": {
    "title": "UTest 教师考试系统操作指南",
    "source_pdf": "utest_guide_teachers_en.pdf",
    "description": "UTest考试系统的完整教师操作指南，涵盖题目创建、考试设计、考试管理、监考、批改和成绩分析"
  },
  "nodes": [
    {
      "id": "ut_root",
      "title": "UTest 考试系统",
      "description": "UTest是ULearning平台的在线考试系统，教师可创建题目、设计考试、管理考场、监考和批改成绩",
      "icon": "📝",
      "color": "#E65100"
    },
    {
      "id": "ut_intro",
      "title": "UTest 系统简介",
      "description": "UTest系统概述及高层级考试流程介绍",
      "icon": "📖",
      "color": "#EF6C00"
    },
    {
      "id": "ut_process",
      "title": "考试流程总览",
      "description": "从创建题目→创建考试→创建考试场次→管理/交付考试→监考→批改/成绩的完整高层级流程",
      "icon": "🔄",
      "color": "#F57C00"
    },
    {
      "id": "ut_create_questions",
      "title": "创建考试题目",
      "description": "支持手动逐题创建、Excel批量导入、点击插入/复制批量创建、复制题目等多种方式",
      "icon": "❓",
      "color": "#FF8F00"
    },
    {
      "id": "ut_q_manual",
      "title": "手动创建题目",
      "description": "手动逐题创建考试题目，支持13种题型",
      "icon": "✍️",
      "color": "#FFA000"
    },
    {
      "id": "ut_q_types",
      "title": "13种题型",
      "description": "支持单选、多选、判断、填空、简答、匹配、排序、完形填空等13种考试题型",
      "icon": "📊",
      "color": "#FFB300"
    },
    {
      "id": "ut_q_manage",
      "title": "题目管理",
      "description": "题库中题目的查看、编辑、分类和管理操作",
      "icon": "📁",
      "color": "#FFC107"
    },
    {
      "id": "ut_q_import",
      "title": "Excel批量导入题目",
      "description": "使用Excel模板批量导入考试题目，提高出题效率",
      "icon": "📤",
      "color": "#FFD54F"
    },
    {
      "id": "ut_q_batch",
      "title": "批量创建题目",
      "description": "通过点击插入/复制方式批量创建考试题目",
      "icon": "📋",
      "color": "#FFE082"
    },
    {
      "id": "ut_q_duplicate",
      "title": "复制题目",
      "description": "从已有题目快速复制创建新题目",
      "icon": "📑",
      "color": "#FFF176"
    },
    {
      "id": "ut_create_exam",
      "title": "创建考试",
      "description": "支持手动创建、自动创建和随机考试三种考试创建方式",
      "icon": "📄",
      "color": "#D84315"
    },
    {
      "id": "ut_exam_manual",
      "title": "手动创建考试",
      "description": "教师手动选择题目、设置分数和考试参数来创建考试",
      "icon": "🖊️",
      "color": "#E64A19"
    },
    {
      "id": "ut_exam_auto",
      "title": "自动创建考试",
      "description": "系统根据设定规则自动从题库中抽取题目生成考试",
      "icon": "🤖",
      "color": "#F4511E"
    },
    {
      "id": "ut_exam_duplicate",
      "title": "复制考试",
      "description": "从已有考试快速复制创建新考试",
      "icon": "📑",
      "color": "#FF5722"
    },
    {
      "id": "ut_exam_random",
      "title": "创建随机考试",
      "description": "创建随机考试，每位学生获得不同的随机题目组合",
      "icon": "🎲",
      "color": "#FF7043"
    },
    {
      "id": "ut_create_offering",
      "title": "创建考试场次",
      "description": "为已创建的考试安排具体的考试场次（课程考试），可使用预创建考试或随机考试",
      "icon": "📅",
      "color": "#BF360C"
    },
    {
      "id": "ut_offer_precreated",
      "title": "使用预创建考试的场次",
      "description": "使用预先创建好的考试来创建考试场次，设置时间、地点等参数",
      "icon": "✅",
      "color": "#D84315"
    },
    {
      "id": "ut_offer_random",
      "title": "使用随机考试的场次",
      "description": "使用随机考试创建考试场次，每个学生获得不同的题目组合",
      "icon": "🔀",
      "color": "#E64A19"
    },
    {
      "id": "ut_manage_exam",
      "title": "管理/交付考试",
      "description": "考试信息查看与编辑、考场管理、评分分配、学生身份验证等",
      "icon": "⚙️",
      "color": "#4E342E"
    },
    {
      "id": "ut_exam_info",
      "title": "查看/编辑考试信息",
      "description": "查看考试详细信息并进行编辑修改",
      "icon": "📝",
      "color": "#5D4037"
    },
    {
      "id": "ut_exam_session",
      "title": "管理考试会话",
      "description": "管理考试的具体会话/场次安排",
      "icon": "🗓️",
      "color": "#6D4C41"
    },
    {
      "id": "ut_exam_facility",
      "title": "考场管理",
      "description": "添加、更新和删除考试设施（考场），并进行考场排班",
      "icon": "🏢",
      "color": "#795548"
    },
    {
      "id": "ut_exam_schedule",
      "title": "考场排班",
      "description": "为考试设施安排具体的考试时间和监考安排",
      "icon": "📆",
      "color": "#8D6E63"
    },
    {
      "id": "ut_grading_assign",
      "title": "分配/管理评分",
      "description": "分配评分教师和管理评分任务",
      "icon": "👥",
      "color": "#A1887F"
    },
    {
      "id": "ut_face_verify",
      "title": "学生人脸照片验证",
      "description": "通过人脸照片验证考生身份，确保考试公正性",
      "icon": "📸",
      "color": "#BCAAA4"
    },
    {
      "id": "ut_alt_code",
      "title": "替代验证码",
      "description": "当人脸验证不可用时，使用替代验证码进行考生身份确认",
      "icon": "🔢",
      "color": "#D7CCC8"
    },
    {
      "id": "ut_proctor",
      "title": "监考",
      "description": "考试监考站和实时监控考试过程",
      "icon": "👁️",
      "color": "#37474F"
    },
    {
      "id": "ut_proctor_station",
      "title": "考试监考站",
      "description": "监考教师的专用监考工作站界面",
      "icon": "🖥️",
      "color": "#455A64"
    },
    {
      "id": "ut_monitor_log",
      "title": "监控考试/查看日志",
      "description": "实时监控考试进行状态并查看考试操作日志",
      "icon": "📊",
      "color": "#546E7A"
    },
    {
      "id": "ut_grading",
      "title": "批改考试/考试成绩",
      "description": "考试批改流程及成绩管理，包括批改、成绩查看、导出等",
      "icon": "✏️",
      "color": "#1B5E20"
    },
    {
      "id": "ut_grade_course",
      "title": "批改课程考试",
      "description": "对课程考试进行逐题批改评分",
      "icon": "📝",
      "color": "#2E7D32"
    },
    {
      "id": "ut_results_overview",
      "title": "成绩总览",
      "description": "考试成绩的总览界面，查看所有学生成绩概况",
