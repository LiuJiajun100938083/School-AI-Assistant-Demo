# ============================================================
# Docker Environment Configuration
# Copy this file to .env.docker and fill in real values:
#   cp .env.docker.example .env.docker
# ============================================================

# ── Database (native MySQL on Mac host) ──
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=demo_app
DB_PASSWORD=CHANGE_ME_TO_REAL_PASSWORD
DB_NAME=school_ai_assistant

# ── JWT ──
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS

# ── Server ──
SERVER_HOST=0.0.0.0
SERVER_PORT=8002
SERVER_DEBUG=false
SERVER_RELOAD=false

# ── Environment ──
ENVIRONMENT=production

# ── LLM (native Ollama on Mac host) ──
LLM_LOCAL_MODEL=qwen3.5:35b-a3b
LLM_LOCAL_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_USE_API=false
# LLM_API_KEY=sk-xxx  # uncomment if using DeepSeek API

# ── Dictation OCR (默書) ──
# OCR_PROVIDER_EN: 英文默書 OCR 引擎 (建議: vision_llm)
#
#   - vision_llm  : Qwen-VL + forensic prompt — 對任何紙張(白紙、筆記紙、
#                   方格紙)都能正確忽略背景,只讀手寫。學校場景首選。
#                   ✓ 推薦 (default)
#
#   - trocr_local : Microsoft TrOCR-large-handwritten + OpenCV 行偵測。
#                   實驗性 — 是純 forensic OCR (絕對不糾錯),但有兩個
#                   重大限制:
#                     (a) 學生必須用乾淨白紙,不能用筆記紙/方格紙
#                     (b) 對任何非文字 crop 會 hallucinate (吐 Wikipedia 風假字)
#                   只適合「實驗室條件下的乾淨樣本」。
OCR_PROVIDER_EN=vision_llm
# TROCR_MODEL=microsoft/trocr-large-handwritten
# TROCR_DEVICE=auto                  # auto / cpu / cuda
# TROCR_WARMUP_ON_START=false        # true=啟動時預載模型
# OCR_PROVIDER_ZH=vision_llm         # 中文目前只有 vision_llm

# LLM 判分層 (看不到圖,只看 OCR 字串 + diff,給評語)
DICTATION_GRADER_ENABLED=true
DICTATION_GRADER_TIMEOUT_SEC=30
DICTATION_OCR_MIN_CONFIDENCE=0.5     # 低於此值 → submission 設 needs_review
DICTATION_GRADER_MIN_CONFIDENCE=0.6  # 低於此值 → submission 設 needs_review

# ── Maintenance Mode ──
MAINTENANCE_MODE=false

# ── Ngrok ──
NGROK_DOMAIN=demo-ai-learning-buddy.ngrok.app

# ── Domain Redirect (旧域名自动跳转到新域名) ──
# 格式: 旧域名>新域名 (多个用逗号分隔)
DOMAIN_REDIRECTS=observantly-galling-lilyana.ngrok-free.dev>demo-ai-learning-buddy.ngrok.app
