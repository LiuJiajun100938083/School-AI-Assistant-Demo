# ============================================================
# Docker Environment Configuration
# Copy this file to .env.docker and fill in real values:
#   cp .env.docker.example .env.docker
# ============================================================

# ── Database (native MySQL on Mac host) ──
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=pkms_app
DB_PASSWORD=CHANGE_ME_TO_REAL_PASSWORD
DB_NAME=school_ai_assistant

# ── JWT ──
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS

# ── Server ──
SERVER_HOST=0.0.0.0
SERVER_PORT=8002
SERVER_DEBUG=false
SERVER_RELOAD=false

# ── Environment ──
ENVIRONMENT=production

# ── LLM (native Ollama on Mac host) ──
LLM_LOCAL_MODEL=qwen3.5:35b-a3b
LLM_LOCAL_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_USE_API=false
# LLM_API_KEY=sk-xxx  # uncomment if using DeepSeek API

# ── Maintenance Mode ──
MAINTENANCE_MODE=false

# ── Ngrok (uncomment and set your domain) ──
# NGROK_DOMAIN=your-domain.ngrok-free.app
